# ─────────────────────────────────────────────
# Database (variables separadas que usa application.yaml)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iam_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
# SSL: usar 'false' + 'disable' para dev local; 'true' + 'require' para producción
DB_SSL_ENABLED=false
DB_SSL_MODE=disable

# ─────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rabbitmq
RABBITMQ_PASSWORD=rabbitmq

# ─────────────────────────────────────────────
# JWT — sin defaults en el YAML, OBLIGATORIO definirlos
# Generar con: openssl rand -hex 32  (produce 64 caracteres hex = 256 bits)
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─────────────────────────────────────────────
# Eureka
# ─────────────────────────────────────────────
EUREKA_URL=http://localhost:8761/eureka

# ─────────────────────────────────────────────
# Spring / Servidor
# ─────────────────────────────────────────────
DDL_AUTO=update
PORT=8081
